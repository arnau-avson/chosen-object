# ── Base de datos ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=chose-objet

# ── JWT ──────────────────────────────────────────────────────
# Cambia este valor en producción por una cadena larga y aleatoria
JWT_SECRET_KEY=cambia-esto-en-produccion-usa-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── App ──────────────────────────────────────────────────────
APP_NAME=Chosen Object
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
